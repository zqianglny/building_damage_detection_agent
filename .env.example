# Agent 工具后端：
# 建筑物定位：provided_mask / gt_mask / external_mask / xview2_baseline
# 损毁评估：provided_mask / gt_mask / external_mask / diff_fallback / xview2_baseline / xview2_strong_baseline
# 当前可直接运行的是 provided_mask/gt_mask/external_mask/diff_fallback；
# xview2_baseline 和 xview2_strong_baseline 是推荐接入的外部模型工具位。
LOCALIZATION_BACKEND=provided_mask
DAMAGE_BACKEND=provided_mask

# 外部工具命令模板。不要给占位符额外加引号；路径会自动处理。
# 可用占位符：{pre_image} {post_image} {pre_mask} {post_damage_mask} {out_dir} {output_mask}
# LOCALIZATION_COMMAND=python /path/to/infer_localization.py --pre {pre_image} --post {post_image} --output {output_mask}
# DAMAGE_COMMAND=python /path/to/infer_damage.py --pre {pre_image} --post {post_image} --pre-mask {pre_mask} --output {output_mask}
EXTERNAL_TOOL_TIMEOUT=1800

# 兼容旧变量：同时控制定位和损毁后端，不建议新配置继续使用。
PREDICTOR_BACKEND=gt_mask

# 多模态解释与复核后端：mock / qwen_multimodal / qwen_text
# VLM_BACKEND 优先级高于旧变量 MLLM_BACKEND；保留 MLLM_BACKEND 是为了兼容旧脚本。
VLM_BACKEND=mock
# MLLM_BACKEND=mock

# Qwen3.5-4B 模型名称或本地路径，仅在 VLM_BACKEND=qwen_multimodal/qwen_text 时使用
MLLM_MODEL_NAME=Qwen/Qwen3.5-4B

# 可选：LoRA/QLoRA adapter 路径；留空表示只使用基础模型
# MLLM_ADAPTER_PATH=/root/autodl-tmp/xbd-rs-mllm-agent/outputs/lora_qwen35_xbd_review

# 推理设备：auto / cuda / cpu
MLLM_DEVICE=auto

# 默认输出目录
OUTPUT_DIR=outputs

# 官方 xView2 baseline 本地路径与权重。配置后可直接使用：
# LOCALIZATION_BACKEND=xview2_baseline
# DAMAGE_BACKEND=xview2_baseline
# XVIEW2_REPO=/root/autodl-tmp/xView2_baseline
# XVIEW2_LOCALIZATION_WEIGHTS=/root/autodl-tmp/xView2_baseline/weights/localization.h5
# XVIEW2_CLASSIFICATION_WEIGHTS=/root/autodl-tmp/xView2_baseline/weights/classification.hdf5
# XVIEW2_CONDA_ENV=xview2
